NODE_ENV=production

# PostgreSQL
POSTGRES_USER=dm_app
POSTGRES_PASSWORD=dm_password
POSTGRES_DB=dm_service
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=4000
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://dm_app:dm_password@postgres:5432/dm_service?schema=public
REDIS_URL=redis://redis:6379

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
